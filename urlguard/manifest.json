{
  "manifest_version": 3,
  "name": "InControl — Block Sneaky Redirects & Background Requests",
  "version": "1.0.0",
  "description": "Block sneaky redirects and third-party background requests. You stay in control.",
  "permissions": [
    "webRequest", "webNavigation", "tabs", "storage",
    "declarativeNetRequest", "declarativeNetRequestWithHostAccess"
  ],
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "declarative_net_request": { "rule_resources": [] }
}
